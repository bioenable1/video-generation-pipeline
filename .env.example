# Video Generation Pipeline — copy to .env and fill in values

# VEED Editing API (workspace dashboard → Settings → Enable API)
VEED_API_KEY=
VEED_WEBHOOK_URL=

# fal.ai — hosts VEED Fabric 1.0 and Lipsync endpoints
FAL_KEY=

# ElevenLabs — voiceover generation
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=

# Pexels — free stock video/photo API (https://www.pexels.com/api/)
PEXELS_API_KEY=

# VideoDB — ingest, edit, subtitle, AI gen (https://videodb.io)
VIDEO_DB_API_KEY=

# Optional: Memories.ai for deep video research (seek-and-analyze-video skill)
MEMORIES_AI_API_KEY=

# Optional: OpenAI for image generation fallback
OPENAI_API_KEY=

# Delivery defaults
DEFAULT_ASPECT_RATIO=16:9
DEFAULT_RESOLUTION=1920x1080
DEFAULT_FPS=30
