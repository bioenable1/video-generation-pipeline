{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://video-generation.local/schemas/shot-list.json",
  "title": "Video Shot List",
  "type": "object",
  "required": ["id", "duration_target_sec", "aspect_ratio", "scenes", "acceptance_criteria"],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]*$",
      "description": "Project slug identifier"
    },
    "title": { "type": "string" },
    "subject": { "type": "string", "description": "Topic, product, or concept" },
    "product": { "type": "string", "description": "Alias for subject (legacy)" },
    "video_type": {
      "type": "string",
      "enum": ["product", "explainer", "social", "tutorial", "custom"]
    },
    "style_reference": { "type": "string", "format": "uri" },
    "duration_target_sec": {
      "type": "integer",
      "minimum": 15,
      "maximum": 600
    },
    "aspect_ratio": {
      "type": "string",
      "enum": ["16:9", "9:16", "1:1", "4:5"]
    },
    "tone": { "type": "string" },
    "approved": {
      "type": "boolean",
      "default": false,
      "description": "Must be true before asset generation phase"
    },
    "approved_at": { "type": "string", "format": "date-time" },
    "scenes": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/scene" }
    },
    "acceptance_criteria": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string" }
    },
    "metadata": {
      "type": "object",
      "properties": {
        "youtube_title": { "type": "string", "maxLength": 100 },
        "youtube_description": { "type": "string", "maxLength": 5000 },
        "tags": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    }
  },
  "$defs": {
    "scene": {
      "type": "object",
      "required": ["id", "duration_sec", "narration", "visual"],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^s[0-9]{2,}$"
        },
        "duration_sec": {
          "type": "number",
          "minimum": 1,
          "maximum": 120
        },
        "narration": { "type": "string", "minLength": 1 },
        "on_screen_text": { "type": "string" },
        "bullets": {
          "type": "array",
          "items": { "type": "string" }
        },
        "dramatic": { "type": "boolean", "description": "Darker overlay for hook/problem scenes" },
        "visual": {
          "type": "object",
          "required": ["type"],
          "properties": {
            "type": {
              "type": "string",
              "enum": [
                "stock_video",
                "stock_photo",
                "ai_image",
                "ai_video",
                "product_image",
                "product_clip",
                "screen_recording",
                "talking_head",
                "text_card",
                "logo_slate"
              ]
            },
            "query": { "type": "string" },
            "catalog_key": { "type": "string", "description": "Key in templates/stock_catalog.json" },
            "intent": { "type": "string" },
            "prompt": { "type": "string" },
            "source_path": { "type": "string" },
            "reference_url": { "type": "string" }
          }
        },
        "audio": {
          "type": "object",
          "properties": {
            "music": { "type": "string" },
            "sfx": { "type": "string" }
          }
        },
        "transition": {
          "type": "string",
          "enum": ["cut", "fade", "dissolve", "slide"]
        }
      }
    }
  }
}
